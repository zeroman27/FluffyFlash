<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.wist.Wist.PrivilegedHelper</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Library/PrivilegedHelperTools/com.wist.Wist.PrivilegedHelper</string>
	</array>
	<key>MachServices</key>
	<dict>
		<key>com.wist.Wist.PrivilegedHelper</key>
		<true/>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/var/log/com.wist.Wist.PrivilegedHelper.log</string>
	<key>StandardErrorPath</key>
	<string>/var/log/com.wist.Wist.PrivilegedHelper.log</string>
</dict>
</plist>

